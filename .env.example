# --- LLM Provider ---
GOOGLE_API_KEY=your_google_api_key_here

# --- Tools ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- Observability (LangSmith) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT="autonomous-research-agent"

# --- API Config ---
PORT=8000
HOST=0.0.0.0
RELOAD=true

# --- Security ---
# AUTH_MODE: "required" (default) = API_KEY must be set and every request
#            must include X-API-Key header.
#            "optional" = open mode when API_KEY is empty (dev convenience).
AUTH_MODE=required
# The shared secret checked against the X-API-Key header.
API_KEY=
# Comma-separated allowed origins; empty = deny all CORS
CORS_ALLOW_ORIGINS=
# slowapi rate limit string
RATE_LIMIT=10/minute

# --- Data Backends (optional — in-memory fallback when unset) ---
# Redis cache: set URL to enable RedisCache (pip install redis)
# REDIS_URL=redis://localhost:6379/0
# FAISS vector store: set path to enable FAISSVectorStore
# VECTOR_DB_PATH=./data/faiss_index
# Chroma vector store: set dir to enable ChromaVectorStore (pip install chromadb)
# CHROMA_PERSIST_DIR=./data/chroma
# Embedding model for FAISS / Chroma backends
# EMBEDDING_MODEL=models/embedding-001

# --- Caps & Thresholds ---
MAX_SUB_QUESTIONS=6
MAX_DOCS_PER_SUBQUERY=5
MAX_DOCS_TOTAL=30
MAX_ITERATIONS=3
SCORE_THRESHOLD=0.8
